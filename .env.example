# Copy to .env.local for local development
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only — Vercel env (NOT NEXT_PUBLIC). From Supabase → Project Settings → API → service_role
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional — run SQL migrations locally
# DATABASE_URL=postgresql://postgres.[ref]:[password]@...

# Optional — configure auth redirect URLs + Google OAuth via npm run supabase:configure
# SUPABASE_ACCESS_TOKEN=sbp_...
# SUPABASE_PROJECT_REF=your-project-ref
# SITE_URL=https://your-app.vercel.app
# GOOGLE_CLIENT_ID=...
# GOOGLE_CLIENT_SECRET=...
